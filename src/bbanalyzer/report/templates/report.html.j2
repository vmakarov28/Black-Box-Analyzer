<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>{{ craft_name }} -- blackbox analysis</title>
<style>
  :root {
    --bg: #0f1420; --panel: #161d2e; --panel-2: #1d2740; --border: #2a3550;
    --text: #e6ebf5; --muted: #8a95b3; --accent: #4f8fe8;
    --crit: #e5484d; --warn: #f5a623; --adv: #4f8fe8; --info: #8a95b3;
  }
  * { box-sizing: border-box; }
  body {
    background: var(--bg); color: var(--text); font-family: -apple-system, "Segoe UI", Roboto, sans-serif;
    margin: 0; padding: 24px; line-height: 1.5;
  }
  .wrap { max-width: 1180px; margin: 0 auto; }
  header { margin-bottom: 24px; }
  h1 { font-size: 1.5rem; margin: 0 0 4px; }
  .subtitle { color: var(--muted); font-size: 0.9rem; }
  .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 12px; margin: 16px 0; }
  .card {
    background: var(--panel); border: 1px solid var(--border); border-radius: 10px; padding: 14px 16px;
  }
  .card h3 { margin: 0 0 6px; font-size: 0.75rem; text-transform: uppercase; letter-spacing: .04em; color: var(--muted); }
  .card .value { font-size: 1.3rem; font-weight: 600; }
  section { margin: 28px 0; }
  section > h2 { font-size: 1.05rem; border-bottom: 1px solid var(--border); padding-bottom: 8px; margin-bottom: 14px; }
  .finding {
    background: var(--panel); border: 1px solid var(--border); border-left: 4px solid var(--info);
    border-radius: 8px; padding: 14px 16px; margin-bottom: 12px;
  }
  .finding.critical { border-left-color: var(--crit); }
  .finding.warning { border-left-color: var(--warn); }
  .finding.advisory { border-left-color: var(--adv); }
  .finding.info { border-left-color: var(--info); }
  .finding-head { display: flex; align-items: baseline; gap: 10px; flex-wrap: wrap; }
  .finding-head .title { font-weight: 600; }
  .badge {
    font-size: 0.68rem; text-transform: uppercase; letter-spacing: .03em; padding: 2px 8px;
    border-radius: 999px; border: 1px solid var(--border); color: var(--muted);
  }
  .badge.recommended { background: var(--accent); color: #fff; border-color: var(--accent); }
  .badge.question { background: transparent; border-color: var(--warn); color: var(--warn); }
  .finding-body { margin-top: 8px; font-size: 0.92rem; }
  .finding-body p { margin: 4px 0; }
  .label { color: var(--muted); font-size: 0.78rem; }
  pre.diff {
    background: #0a0e18; border: 1px solid var(--border); border-radius: 6px; padding: 10px 12px;
    overflow-x: auto; font-size: 0.85rem; margin: 8px 0 0;
  }
  .observations { color: var(--muted); font-size: 0.88rem; }
  .observations li { margin: 3px 0; }
  img.plot { width: 100%; border-radius: 8px; border: 1px solid var(--border); background: #fff; }
  table.metrics { width: 100%; border-collapse: collapse; font-size: 0.85rem; }
  table.metrics td, table.metrics th { padding: 5px 10px; border-bottom: 1px solid var(--border); text-align: left; }
  table.metrics th { color: var(--muted); font-weight: 500; }
  footer { color: var(--muted); font-size: 0.78rem; margin-top: 32px; border-top: 1px solid var(--border); padding-top: 12px; }
  .warn-banner {
    background: #3a2410; border: 1px solid var(--warn); color: var(--warn); border-radius: 8px;
    padding: 10px 14px; margin-bottom: 16px; font-size: 0.9rem;
  }
  details.raw-header summary { cursor: pointer; color: var(--muted); font-size: 0.85rem; }
  details.raw-header pre { max-height: 300px; overflow: auto; font-size: 0.78rem; }
</style>
</head>
<body>
<div class="wrap">

<header>
  <h1>{{ craft_name }}</h1>
  <div class="subtitle">{{ firmware_line }} &middot; log: {{ log_filename }} &middot; generated {{ generated_at }}</div>
</header>

{% if version_mismatch_warning %}
<div class="warn-banner">&#9888; {{ version_mismatch_warning }}</div>
{% endif %}

<section>
  <h2>Flight overview</h2>
  <div class="grid">
    <div class="card"><h3>Duration</h3><div class="value">{{ duration_s }}s</div></div>
    <div class="card"><h3>Frames</h3><div class="value">{{ n_frames }}</div></div>
    <div class="card"><h3>Sample rate</h3><div class="value">{{ sample_rate_hz }}Hz</div></div>
    <div class="card"><h3>Throttle chops</h3><div class="value">{{ throttle_chop_count }}</div></div>
    <div class="card"><h3>Findings</h3><div class="value">{{ n_findings }}</div></div>
    <div class="card"><h3>Recommended changes</h3><div class="value">{{ n_recommended }}</div></div>
  </div>
  <p>{{ narrative_summary }}</p>
</section>

<section>
  <h2>Recommended changes for the next test flight</h2>
  {% if narrative_items %}
    {% for item in narrative_items %}
    <div class="finding {{ item.severity }}">
      <div class="finding-head">
        <span class="title">{{ item.title }}</span>
        <span class="badge recommended">recommended</span>
        {% if item.is_question %}<span class="badge question">low confidence</span>{% endif %}
        <span class="badge">{{ item.confidence }} confidence</span>
      </div>
      <div class="finding-body">
        <p>{{ item.whats_wrong }}</p>
        <p class="label">Why:</p>
        <p>{{ item.why_plain_english }}</p>
        {% if item.cli_diff %}
        <p class="label">CLI change:</p>
        <pre class="diff">{{ item.cli_diff | join('\n') }}</pre>
        {% endif %}
        <p class="label">Test-flight procedure:</p>
        <p>{{ item.test_flight_procedure }}</p>
      </div>
    </div>
    {% endfor %}
  {% else %}
    <p class="observations">No findings met the bar for a recommended change this round.</p>
  {% endif %}
</section>

{% if other_observations %}
<section>
  <h2>Other observations</h2>
  <ul class="observations">
    {% for obs in other_observations %}<li>{{ obs }}</li>{% endfor %}
  </ul>
</section>
{% endif %}

<section>
  <h2>Step response</h2>
  <img class="plot" src="{{ step_response_plot }}" alt="step response plot">
</section>

<section>
  <h2>Noise (throttle vs frequency)</h2>
  <img class="plot" src="{{ noise_heatmap_plot }}" alt="noise heatmap plot">
</section>

<section>
  <h2>Filtering &amp; propwash summary</h2>
  <img class="plot" src="{{ filter_propwash_plot }}" alt="filter and propwash summary plot">
</section>

{% if compare %}
<section>
  <h2>Compare: {{ compare.before_label }} vs {{ compare.after_label }}</h2>
  <table class="metrics">
    <tr><th>Metric</th><th>{{ compare.before_label }}</th><th>{{ compare.after_label }}</th><th>Delta</th></tr>
    {% for row in compare.rows %}
    <tr><td>{{ row.name }}</td><td>{{ row.before }}</td><td>{{ row.after }}</td><td>{{ row.delta }}</td></tr>
    {% endfor %}
  </table>
</section>
{% endif %}

{% if tune_plan %}
<section>
  <h2>Tune generator: staged CLI changes</h2>
  {% if tune_plan.warnings %}
  <div class="warn-banner">
    {% for w in tune_plan.warnings %}&#9888; {{ w }}<br>{% endfor %}
  </div>
  {% endif %}
  <p class="label">Source config: {{ tune_plan.source }}{% if tune_plan.simplified_tuning_active %} &middot; simplified tuning is active{% endif %}</p>
  {% for stage in tune_plan.stages %}
  <div class="finding">
    <div class="finding-head"><span class="title">Stage {{ loop.index }}</span></div>
    <pre class="diff">{% for c in stage %}set {{ c.key }} = {{ c.new_value }}{% if c.old_value %}   # was {{ c.old_value }}{% endif %}
{% endfor %}save</pre>
    <p class="label">Fly one test flight after this stage, then re-run bbanalyzer before applying the next.</p>
  </div>
  {% endfor %}
  {% if tune_plan.rejected %}
  <p class="label">Flagged for human review (never emitted):</p>
  <ul class="observations">
    {% for r in tune_plan.rejected %}<li><code>{{ r.key }}</code>: {{ r.reason }}</li>{% endfor %}
  </ul>
  {% endif %}
</section>
{% endif %}

{% if rates_report %}
<section>
  <h2>Rates (preference-based, not a tuning defect)</h2>
  <table class="metrics">
    <tr><th>Axis</th><th>Measured p95 stick rate</th><th>Configured max rate</th><th>Note</th></tr>
    {% for r in rates_report %}
    <tr><td>{{ r.axis }}</td><td>{{ r.measured_p95_degps }}</td><td>{{ r.configured_max_degps or '-' }}</td><td>{{ r.configured_max_note }}</td></tr>
    {% endfor %}
  </table>
</section>
{% endif %}

<section>
  <h2>All findings</h2>
  <table class="metrics">
    <tr><th>Severity</th><th>Confidence</th><th>Axis</th><th>Finding</th><th>Trigger</th></tr>
    {% for f in all_findings %}
    <tr><td>{{ f.severity }}</td><td>{{ f.confidence }}</td><td>{{ f.axis or '-' }}</td><td>{{ f.title }}</td><td>{{ f.trigger_summary }}</td></tr>
    {% endfor %}
  </table>
</section>

<section>
  <details class="raw-header">
    <summary>Raw header config ({{ raw_header|length }} keys)</summary>
    <pre>{% for k, v in raw_header.items() %}{{ k }}: {{ v }}
{% endfor %}</pre>
  </details>
</section>

<footer>
  Generated by bbanalyzer {{ version }} &middot; narrative: {{ generated_by }} &middot; 100% local, no network requests in this file.
</footer>

</div>
</body>
</html>
