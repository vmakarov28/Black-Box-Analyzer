<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>Compare: {{ before_label }} vs {{ after_label }}</title>
<style>
  :root { --bg: #0f1420; --panel: #161d2e; --border: #2a3550; --text: #e6ebf5; --muted: #8a95b3; --good: #2f9e5b; --bad: #e5484d; }
  * { box-sizing: border-box; }
  body { background: var(--bg); color: var(--text); font-family: -apple-system, "Segoe UI", Roboto, sans-serif; margin: 0; padding: 24px; line-height: 1.5; }
  .wrap { max-width: 980px; margin: 0 auto; }
  h1 { font-size: 1.4rem; margin: 0 0 4px; }
  .subtitle { color: var(--muted); font-size: 0.9rem; margin-bottom: 20px; }
  table.metrics { width: 100%; border-collapse: collapse; font-size: 0.9rem; margin-bottom: 24px; }
  table.metrics td, table.metrics th { padding: 6px 12px; border-bottom: 1px solid var(--border); text-align: left; }
  table.metrics th { color: var(--muted); font-weight: 500; }
  .improved { color: var(--good); }
  .regressed { color: var(--bad); }
  img.plot { width: 100%; border-radius: 8px; border: 1px solid var(--border); background: #fff; margin-bottom: 20px; }
  footer { color: var(--muted); font-size: 0.78rem; margin-top: 20px; border-top: 1px solid var(--border); padding-top: 12px; }
</style>
</head>
<body>
<div class="wrap">
<h1>Compare: {{ before_label }} vs {{ after_label }}</h1>
<div class="subtitle">Verifies whether a staged tuning change actually helped -- both numbers are always shown, never just a verdict.</div>

<img class="plot" src="{{ step_response_plot }}" alt="step response comparison">

<table class="metrics">
<tr><th>Metric</th><th>{{ before_label }}</th><th>{{ after_label }}</th><th>Delta</th></tr>
{% for row in rows %}
<tr>
  <td>{{ row.name }}</td>
  <td>{{ row.before }}</td>
  <td>{{ row.after }}</td>
  <td class="{{ 'improved' if row.improved == True else ('regressed' if row.improved == False else '') }}">{{ row.delta }}</td>
</tr>
{% endfor %}
</table>

<footer>Generated by bbanalyzer {{ version }} &middot; 100% local, no network requests in this file.</footer>
</div>
</body>
</html>
