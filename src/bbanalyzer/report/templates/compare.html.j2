<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>Compare: {{ before_label }} vs {{ after_label }}</title>
<style>
  :root {
    --bg: #0a0a0a; --bg-alt: #141414; --panel: #1a1a1a; --border: #333333; --border-2: #3d3d3d;
    --text: #f2f2f2; --muted: #9c9c9c; --muted-2: #737373;
    --primary: #ffbb00; --primary-light: #ffc526;
    --success: #96e212; --error: #e2123f; --error-light: #ee2b55;
    --radius: 6px; --radius-sm: 3px;
  }
  html[data-theme="light"] {
    --bg: #ffffff; --bg-alt: #fafafa; --panel: #f7f7f7; --border: #d6d6d6; --border-2: #bfbfbf;
    --text: #0a0a0a; --muted: #595959; --muted-2: #757575;
  }
  * { box-sizing: border-box; }
  body {
    background: var(--bg); color: var(--text); font-family: "Open Sans", "Segoe UI", Tahoma, sans-serif;
    margin: 0; padding: 0; line-height: 1.55; font-size: 14px;
  }
  .topbar { background: var(--bg-alt); border-bottom: 1px solid var(--border); padding: 14px 24px; display: flex; align-items: center; gap: 8px; }
  .topbar .dot { width: 9px; height: 9px; border-radius: 50%; background: var(--success); box-shadow: 0 0 6px var(--success); }
  .topbar b { font-size: 0.85rem; }
  .theme-toggle {
    margin-left: auto; background: none; border: 1px solid var(--border-2); color: var(--muted);
    border-radius: 999px; padding: 5px 12px; font-size: 0.75rem; font-weight: 600; cursor: pointer; font-family: inherit;
  }
  .theme-toggle:hover { color: var(--text); border-color: var(--muted); }
  .wrap { max-width: 1000px; margin: 0 auto; padding: 28px 24px 40px; }
  h1 { font-size: 1.4rem; margin: 0 0 4px; font-weight: 700; letter-spacing: -.01em; }
  .subtitle { color: var(--muted); font-size: 0.85rem; margin-bottom: 24px; }
  /* fixed dark: the inlined PNGs bake their facecolor into the pixels */
  .plot-card { background: #1a1a1a; border: 1px solid var(--border-2); border-radius: var(--radius); padding: 12px; margin-bottom: 24px; }
  img.plot { width: 100%; display: block; border-radius: var(--radius-sm); }
  table.metrics { width: 100%; border-collapse: collapse; font-size: 0.88rem; margin-bottom: 24px; }
  table.metrics td, table.metrics th { padding: 8px 12px; border-bottom: 1px solid var(--border); text-align: left; }
  table.metrics th { color: var(--muted-2); font-weight: 600; font-size: 0.7rem; text-transform: uppercase; letter-spacing: .05em; }
  table.metrics tbody tr:hover { background: var(--bg-alt); }
  .improved { color: var(--success); font-weight: 700; }
  .regressed { color: var(--error-light); font-weight: 700; }
  footer { color: var(--muted-2); font-size: 0.78rem; margin-top: 20px; border-top: 1px solid var(--border); padding-top: 12px; }
  @media print {
    .theme-toggle { display: none !important; }
    html[data-theme] { --bg: #fff; --bg-alt: #fff; --panel: #fff; --text: #000; --muted: #444; --border: #ccc; }
  }
</style>
<script>
  (function () {
    var t = "dark";
    try { t = localStorage.getItem("bbanalyzer-theme") || "dark"; } catch (e) {}
    document.documentElement.setAttribute("data-theme", t);
  })();
  function bbToggleTheme() {
    var html = document.documentElement;
    var next = html.getAttribute("data-theme") === "light" ? "dark" : "light";
    html.setAttribute("data-theme", next);
    try { localStorage.setItem("bbanalyzer-theme", next); } catch (e) {}
    var btn = document.getElementById("themeToggle");
    if (btn) btn.textContent = next === "light" ? "Dark mode" : "Light mode";
  }
</script>
</head>
<body>
<div class="topbar">
  <span class="dot"></span><b>bbanalyzer</b>
  <button class="theme-toggle" id="themeToggle" onclick="bbToggleTheme()" type="button">Light mode</button>
  <script>
    (function () {
      var btn = document.getElementById("themeToggle");
      if (btn && document.documentElement.getAttribute("data-theme") === "light") { btn.textContent = "Dark mode"; }
    })();
  </script>
</div>
<div class="wrap">
<h1>Compare: {{ before_label }} vs {{ after_label }}</h1>
<div class="subtitle">Verifies whether a staged tuning change actually helped -- both numbers are always shown, never just a verdict.</div>

<div class="plot-card"><img class="plot" src="{{ step_response_plot }}" alt="step response comparison"></div>

<table class="metrics">
<tr><th>Metric</th><th>{{ before_label }}</th><th>{{ after_label }}</th><th>Delta</th></tr>
{% for row in rows %}
<tr>
  <td>{{ row.name }}</td>
  <td>{{ row.before }}</td>
  <td>{{ row.after }}</td>
  <td class="{{ 'improved' if row.improved == True else ('regressed' if row.improved == False else '') }}">{{ row.delta }}</td>
</tr>
{% endfor %}
</table>

<footer>Generated by bbanalyzer {{ version }} &middot; 100% local, no network requests in this file.</footer>
</div>
</body>
</html>
