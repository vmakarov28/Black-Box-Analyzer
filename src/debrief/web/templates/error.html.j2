<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>Debrief -- couldn't analyze that</title>
<style>
{{ theme_css }}
  .wrap { max-width: 640px; margin: 80px auto; padding: 0 24px; text-align: center; }
  .icon { font-size: 2.4rem; margin-bottom: 8px; }
  h1 { font-size: 1.3rem; margin: 0 0 12px; }
</style>
<script>{{ theme_script_head }}</script>
</head>
<body>
