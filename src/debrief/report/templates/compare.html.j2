<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>Compare: {{ before_label }} vs {{ after_label }} -- Debrief</title>
<style>
{{ theme_css }}

  .wrap { max-width: 1000px; margin: 0 auto; padding: 28px 24px 40px; }
  h1 { font-size: 1.4rem; margin: 0 0 4px; font-weight: 700; letter-spacing: -.01em; }
  .subtitle { color: var(--muted); font-size: 0.85rem; margin-bottom: 24px; }
  /* fixed dark: the inlined PNGs bake their facecolor into the pixels */
  .plot-card { background: #1a1a1a; border: 1px solid var(--border-2); border-radius: var(--radius); padding: 12px; margin-bottom: 24px; }
  img.plot { width: 100%; display: block; border-radius: var(--radius-sm); }
  .improved { color: var(--success); font-weight: 700; }
  .regressed { color: var(--error-light); font-weight: 700; }
  table.metrics { margin-bottom: 24px; }
</style>
<script>{{ theme_script_head }}</script>
</head>
<body>
<div class="topbar">
  <div class="topbar-inner">
    <a class="brand" href="{{ home_url or '#' }}"><span class="dot"></span><b>Debrief</b></a>
    <nav>
      <button class="btn btn-ghost" id="downloadBtn" onclick="bbDownloadReport()" type="button" style="margin-left:auto;margin-right:8px;">Download report</button>
      <button class="theme-toggle" id="themeToggle" onclick="bbToggleTheme()" type="button">Light mode</button>
      <script>{{ theme_script_sync }}</script>
    </nav>
  </div>
</div>
<div class="wrap">
<h1>Compare: {{ before_label }} vs {{ after_label }}</h1>
<div class="subtitle">Verifies whether a staged tuning change actually helped -- both numbers are always shown, never just a verdict.</div>

<div class="plot-card"><img class="plot" src="{{ step_response_plot }}" alt="step response comparison"></div>

<table class="metrics">
<tr><th>Metric</th><th>{{ before_label }}</th><th>{{ after_label }}</th><th>Delta</th></tr>
{% for row in rows %}
<tr>
  <td>{{ row.name }}</td>
  <td>{{ row.before }}</td>
  <td>{{ row.after }}</td>
  <td class="{{ 'improved' if row.improved == True else ('regressed' if row.improved == False else '') }}">{{ row.delta }}</td>
</tr>
{% endfor %}
</table>

<footer>
  <span>Generated by Debrief {{ version }}</span>
  <span><span class="dot">&#9679;</span> 100% local, no network requests in this file</span>
</footer>
</div>

<script>
  function bbDownloadReport() {
    var html = "<!doctype html>\n" + document.documentElement.outerHTML;
    var blob = new Blob([html], { type: "text/html" });
    var a = document.createElement("a");
    a.href = URL.createObjectURL(blob);
    a.download = "{{ download_filename or 'debrief-compare.html' }}";
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
  }
</script>
</body>
</html>
