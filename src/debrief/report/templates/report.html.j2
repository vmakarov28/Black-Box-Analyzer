<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>{{ craft_name }} -- Debrief</title>
<style>
{{ theme_css }}

  .wrap { max-width: 1180px; margin: 0 auto; padding: 0 24px 40px; }
  header.hero { margin: 28px 0 20px; }
  h1 { font-size: 1.6rem; margin: 0 0 4px; font-weight: 700; letter-spacing: -.01em; }
  .subtitle { color: var(--muted); font-size: 0.85rem; }
  .subtitle code { color: var(--muted-2); }

  .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(170px, 1fr)); gap: 10px; margin: 16px 0; }
  .card {
    background: var(--panel); border: 1px solid var(--border); border-radius: var(--radius);
    padding: 14px 16px; border-top: 2px solid var(--border-2);
  }
  .card h3 { margin: 0 0 6px; font-size: 0.68rem; text-transform: uppercase; letter-spacing: .06em; color: var(--muted-2); font-weight: 600; }
  .card .value { font-size: 1.35rem; font-weight: 700; color: var(--text); font-variant-numeric: tabular-nums; }
  .card.accent { border-top-color: var(--primary); }
  .card.accent .value { color: var(--primary); }

  section { margin: 36px 0; scroll-margin-top: 60px; }
  section > h2 {
    font-size: 0.95rem; text-transform: uppercase; letter-spacing: .05em; font-weight: 700;
    color: var(--text); border-bottom: 1px solid var(--border); padding-bottom: 10px; margin-bottom: 16px;
    display: flex; align-items: center; gap: 8px;
  }
  section > h2::before { content: ""; width: 3px; height: 14px; background: var(--primary); display: inline-block; border-radius: 2px; }

  .finding {
    background: var(--panel); border: 1px solid var(--border); border-left: 3px solid var(--info);
    border-radius: var(--radius); padding: 16px 18px; margin-bottom: 12px;
  }
  .finding.critical { border-left-color: var(--crit); }
  .finding.warning { border-left-color: var(--warn); }
  .finding.advisory { border-left-color: var(--adv); }
  .finding.info { border-left-color: var(--info); }
  .finding-head { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
  .finding-head .title { font-weight: 700; font-size: 0.95rem; }
  .finding-body { margin-top: 10px; font-size: 0.92rem; }
  .finding-body p { margin: 6px 0; }
  .label { color: var(--muted-2); font-size: 0.72rem; text-transform: uppercase; letter-spacing: .05em; font-weight: 600; margin-top: 12px; }
  pre.diff {
    background: #050505; border: 1px solid var(--border-2); border-radius: var(--radius-sm); padding: 12px 14px;
    overflow-x: auto; font-size: 0.85rem; margin: 6px 0 0; color: var(--primary-light);
    font-family: "SF Mono", "Cascadia Mono", Consolas, monospace; line-height: 1.6;
  }
  .observations { color: var(--muted); font-size: 0.88rem; list-style: none; padding: 0; }
  .observations li {
    padding: 8px 12px; margin: 4px 0; background: var(--panel); border: 1px solid var(--border);
    border-radius: var(--radius-sm); border-left: 2px solid var(--border-2);
  }
  .observations li code { color: var(--primary-light); }
  /* Fixed dark, independent of data-theme: the inlined PNGs have their
     matplotlib facecolor baked into the pixels at render time, so the card
     around them stays dark in light mode too rather than mismatching. */
  .plot-card { background: #1a1a1a; border: 1px solid var(--border-2); border-radius: var(--radius); padding: 12px; }
  img.plot { width: 100%; display: block; border-radius: var(--radius-sm); }
  details.raw-header summary {
    cursor: pointer; color: var(--muted); font-size: 0.85rem; padding: 10px 0; font-weight: 600;
  }
  /* pre.diff and this box are deliberately always dark (a "terminal", like
     Configurator's own CLI tab) regardless of data-theme -- fixed colors,
     not theme variables, so light mode never leaves gray-on-near-black. */
  details.raw-header pre {
    max-height: 320px; overflow: auto; font-size: 0.78rem; background: #050505; border: 1px solid var(--border);
    border-radius: var(--radius-sm); padding: 12px 14px; color: #b3b3b3;
    font-family: "SF Mono", Consolas, monospace;
  }
  @media print {
    .wrap { max-width: none; padding: 0 12px; }
    section { margin: 18px 0; page-break-inside: avoid; }
    .finding, .plot-card, .card { border: 1px solid #ccc; }
  }
</style>
<script>{{ theme_script_head }}</script>
</head>
<body>

<div class="topbar">
  <div class="topbar-inner">
    <a class="brand" href="{{ home_url or '#' }}"><span class="dot"></span><b>Debrief</b></a>
    <nav>
      <a href="#overview">Overview</a>
      <a href="#recommended">Recommended</a>
      <a href="#step-response">Step Response</a>
      <a href="#noise">Noise</a>
      <a href="#filtering">Filtering</a>
      {% if tune_plan %}<a href="#tune">Tune Generator</a>{% endif %}
      {% if rates_report %}<a href="#rates">Rates</a>{% endif %}
      <a href="#findings">All Findings</a>
      <button class="btn btn-ghost" id="downloadBtn" onclick="bbDownloadReport()" type="button" style="margin-left:8px;">Download report</button>
      <button class="theme-toggle" id="themeToggle" onclick="bbToggleTheme()" type="button">Light mode</button>
      <script>{{ theme_script_sync }}</script>
    </nav>
  </div>
</div>

<div class="wrap">

<header class="hero" id="overview">
  <h1>{{ craft_name }}</h1>
  <div class="subtitle">{{ firmware_line }} &middot; log: <code>{{ log_filename }}</code> &middot; generated {{ generated_at }}</div>
</header>

{% if version_mismatch_warning %}
<div class="warn-banner">&#9888; {{ version_mismatch_warning }}</div>
{% endif %}

<section>
  <div class="grid">
    <div class="card"><h3>Duration</h3><div class="value">{{ duration_s }}s</div></div>
    <div class="card"><h3>Frames</h3><div class="value">{{ n_frames }}</div></div>
    <div class="card"><h3>Sample rate</h3><div class="value">{{ sample_rate_hz }}Hz</div></div>
    <div class="card"><h3>Throttle chops</h3><div class="value">{{ throttle_chop_count }}</div></div>
    <div class="card"><h3>Findings</h3><div class="value">{{ n_findings }}</div></div>
    <div class="card accent"><h3>Recommended changes</h3><div class="value">{{ n_recommended }}</div></div>
  </div>
  <p>{{ narrative_summary }}</p>
</section>

<section id="recommended">
  <h2>Recommended changes for the next test flight</h2>
  {% if narrative_items %}
    {% for item in narrative_items %}
    <div class="finding {{ item.severity }}">
      <div class="finding-head">
        <span class="title">{{ item.title }}</span>
        <span class="badge recommended">recommended</span>
        {% if item.is_question %}<span class="badge question">low confidence</span>{% endif %}
        <span class="badge sev-{{ item.severity }}">{{ item.confidence }} confidence</span>
      </div>
      <div class="finding-body">
        <p>{{ item.whats_wrong }}</p>
        <p class="label">Why</p>
        <p>{{ item.why_plain_english }}</p>
        {% if item.cli_diff %}
        <p class="label">CLI change</p>
        <pre class="diff">{{ item.cli_diff | join('\n') }}</pre>
        {% endif %}
        <p class="label">Test-flight procedure</p>
        <p>{{ item.test_flight_procedure }}</p>
      </div>
    </div>
    {% endfor %}
  {% else %}
    <ul class="observations"><li>No findings met the bar for a recommended change this round.</li></ul>
  {% endif %}
</section>

{% if other_observations %}
<section>
  <h2>Other observations</h2>
  <ul class="observations">
    {% for obs in other_observations %}<li>{{ obs }}</li>{% endfor %}
  </ul>
</section>
{% endif %}

<section id="step-response">
  <h2>Step response</h2>
  <div class="plot-card"><img class="plot" src="{{ step_response_plot }}" alt="step response plot"></div>
</section>

<section id="noise">
  <h2>Noise (throttle vs frequency)</h2>
  <div class="plot-card"><img class="plot" src="{{ noise_heatmap_plot }}" alt="noise heatmap plot"></div>
</section>

<section id="filtering">
  <h2>Filtering &amp; propwash summary</h2>
  <div class="plot-card"><img class="plot" src="{{ filter_propwash_plot }}" alt="filter and propwash summary plot"></div>
</section>

{% if compare %}
<section>
  <h2>Compare: {{ compare.before_label }} vs {{ compare.after_label }}</h2>
  <table class="metrics">
    <tr><th>Metric</th><th>{{ compare.before_label }}</th><th>{{ compare.after_label }}</th><th>Delta</th></tr>
    {% for row in compare.rows %}
    <tr><td>{{ row.name }}</td><td>{{ row.before }}</td><td>{{ row.after }}</td><td>{{ row.delta }}</td></tr>
    {% endfor %}
  </table>
</section>
{% endif %}

{% if tune_plan %}
<section id="tune">
  <h2>Tune generator: staged CLI changes</h2>
  {% if tune_plan.warnings %}
  <div class="warn-banner">
    {% for w in tune_plan.warnings %}&#9888; {{ w }}<br>{% endfor %}
  </div>
  {% endif %}
  <p class="label">Source config: {{ tune_plan.source }}{% if tune_plan.simplified_tuning_active %} &middot; simplified tuning is active{% endif %}</p>
  {% for stage in tune_plan.stages %}
  <div class="finding">
    <div class="finding-head">
      <span class="title">Stage {{ loop.index }}</span>
      {% if tune_plan.downloads %}<a class="btn btn-ghost" style="padding:4px 10px;font-size:.72rem;" href="{{ tune_plan.downloads[loop.index0] }}" download="stage{{ loop.index }}.txt">Download stage{{ loop.index }}.txt</a>{% endif %}
    </div>
    <pre class="diff">{% for c in stage %}set {{ c.key }} = {{ c.new_value }}{% if c.old_value %}   # was {{ c.old_value }}{% endif %}
{% endfor %}save</pre>
    <p class="label">Next step</p>
    <p>Fly one test flight after this stage, then re-run Debrief before applying the next.</p>
  </div>
  {% endfor %}
  {% if tune_plan.rollback_download %}
  <p><a class="btn btn-ghost" href="{{ tune_plan.rollback_download }}" download="rollback.txt">Download rollback.txt</a>
  {% if tune_plan.changelog_download %}<a class="btn btn-ghost" href="{{ tune_plan.changelog_download }}" download="changelog.md">Download changelog.md</a>{% endif %}</p>
  {% endif %}
  {% if tune_plan.rejected %}
  <p class="label">Flagged for human review (never emitted)</p>
  <ul class="observations">
    {% for r in tune_plan.rejected %}<li><code>{{ r.key }}</code>: {{ r.reason }}</li>{% endfor %}
  </ul>
  {% endif %}
</section>
{% endif %}

{% if rates_report %}
<section id="rates">
  <h2>Rates (preference-based, not a tuning defect)</h2>
  <table class="metrics">
    <tr><th>Axis</th><th>Measured p95 stick rate</th><th>Configured max rate</th><th>Note</th></tr>
    {% for r in rates_report %}
    <tr><td>{{ r.axis }}</td><td>{{ r.measured_p95_degps }}</td><td>{{ r.configured_max_degps or '-' }}</td><td>{{ r.configured_max_note }}</td></tr>
    {% endfor %}
  </table>
</section>
{% endif %}

<section id="findings">
  <h2>All findings</h2>
  <table class="metrics">
    <tr><th>Severity</th><th>Confidence</th><th>Axis</th><th>Finding</th><th>Trigger</th></tr>
    {% for f in all_findings %}
    <tr><td><span class="badge sev-{{ f.severity }}">{{ f.severity }}</span></td><td>{{ f.confidence }}</td><td>{{ f.axis or '-' }}</td><td>{{ f.title }}</td><td><code>{{ f.trigger_summary }}</code></td></tr>
    {% endfor %}
  </table>
</section>

<section>
  <details class="raw-header">
    <summary>Raw header config ({{ raw_header|length }} keys)</summary>
    <pre>{% for k, v in raw_header.items() %}{{ k }}: {{ v }}
{% endfor %}</pre>
  </details>
</section>

<footer>
  <span>Generated by Debrief {{ version }} &middot; narrative: {{ generated_by }}</span>
  <span><span class="dot">&#9679;</span> 100% local, no network requests in this file</span>
</footer>

</div>

<script>
  function bbDownloadReport() {
    var html = "<!doctype html>\\n" + document.documentElement.outerHTML;
    var blob = new Blob([html], { type: "text/html" });
    var a = document.createElement("a");
    a.href = URL.createObjectURL(blob);
    a.download = "{{ download_filename or 'debrief-report.html' }}";
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
  }
</script>
</body>
</html>
